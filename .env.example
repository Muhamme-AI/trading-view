# Supabase Postgres — REQUIRED on Vercel (Settings → Environment Variables)
#
# For Vercel/serverless use the CONNECTION POOLER URI (NOT the direct db.* URL):
# Supabase → Project Settings → Database → Connection string → Connection pooling → URI
#
# Example (replace [YOUR-PASSWORD] and region):
# DATABASE_URL=postgresql://postgres.tlhfdfhpouorqwrahofa:[YOUR-PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
#
# Local dev can use direct connection:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.tlhfdfhpouorqwrahofa.supabase.co:5432/postgres

DATABASE_URL=

SUPABASE_URL=https://tlhfdfhpouorqwrahofa.supabase.co

# AI Advisor (LangChain + LangGraph + RAG)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2
