# Supabase Postgres connection (required)
# Supabase → Project Settings → Database → Connection string → URI
# Use the "Session pooler" or "Direct connection" string and replace [YOUR-PASSWORD]
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional aliases (same value as DATABASE_URL)
# SUPABASE_DB_URL=

# Supabase project URL (for reference / future client-side use)
SUPABASE_URL=https://yzjjgzvausdqfqqsdtjf.supabase.co
